{
  "name": "agentscope",
  "version": "0.1.0",
  "private": false,
  "description": "Open-source DevTools for AI agent traces, prompts, tool calls, MCP activity, and code changes.",
  "scripts": {
    "start": "vite --host 127.0.0.1",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "agentscope": "node scripts/agentscope.js",
    "test": "node scripts/test-importers.js"
  },
  "bin": {
    "agentscope": "scripts/agentscope.js"
  },
  "keywords": [
    "ai-agent",
    "mcp",
    "observability",
    "debugging",
    "developer-tools",
    "llmops",
    "codex",
    "claude-code",
    "trace-viewer"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.7"
  }
}
